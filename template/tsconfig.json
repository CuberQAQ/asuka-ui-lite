{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "@cuberqaq/asuka-ui-lite",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "outDir": "./page",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "app.tsx", "global.d.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
