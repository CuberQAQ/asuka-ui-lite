  "devDependencies": {
    "@zeppos/device-types": "^3.0.0",
    "prettier": "3.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  },
  "keywords": [
    "zepp",
    "zeppos",
    "ui",
    "jsx",
    "framework",
    "watch"
