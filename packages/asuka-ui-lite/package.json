{
  "name": "@cuberqaq/asuka-ui-lite",
  "version": "1.0.1",
  "description": "UI Framework for Zepp OS",
  "repository": {
    "type": "git",
    "url": "https://github.com/CuberQAQ/asuka-ui-lite"
  },
  "author": "CuberQAQ",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
