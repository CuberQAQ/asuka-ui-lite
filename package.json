{
  "name": "asuka-ui-lite-monorepo",
  "private": true,
  "description": "Asuka UI Lite monorepo: reactive core + JSX UI framework + template",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "watch": "pnpm -r --parallel watch",
    "clean": "pnpm -r exec rm -rf dist",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
